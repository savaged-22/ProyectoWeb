package com.lulo.tenant;

public class TenantContext {
  private static final ThreadLocal<Long> COMPANY_ID = new ThreadLocal<>();
  private static final ThreadLocal<Long> POOL_ID = new ThreadLocal<>();

  public static void setCompanyId(Long companyId) { COMPANY_ID.set(companyId); }
  public static Long getCompanyId() { return COMPANY_ID.get(); }
  public static void clearCompanyId() { COMPANY_ID.remove(); }

  public static void setPoolId(Long poolId) { POOL_ID.set(poolId); }
  public static Long getPoolId() { return POOL_ID.get(); }
  public static void clearPoolId() { POOL_ID.remove(); }
}
