# ─── PostgreSQL ───────────────────────────────────────────────────────────────
DB_NAME=lulo
DB_USER=lulo_user
DB_PASSWORD=change_me
DB_PORT=5432

# ─── Spring DataSource ────────────────────────────────────────────────────────
SPRING_DATASOURCE_URL=jdbc:postgresql://db:5432/lulo
SPRING_DATASOURCE_USERNAME=lulo_user
SPRING_DATASOURCE_PASSWORD=change_me

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_use_a_long_random_string
JWT_EXPIRATION_MINUTES=120

# ─── Backend ──────────────────────────────────────────────────────────────────
SERVER_PORT=8080
