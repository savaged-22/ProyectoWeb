# ─── PostgreSQL ───────────────────────────────────────────────────────────────
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_PORT=

# ─── Spring DataSource ────────────────────────────────────────────────────────
SPRING_DATASOURCE_URL=
SPRING_DATASOURCE_USERNAME=
SPRING_DATASOURCE_PASSWORD=c

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=
JWT_EXPIRATION_MINUTES=

# ─── Backend ──────────────────────────────────────────────────────────────────
SERVER_PORT=

# ─── Docker Compose (build context override) ─────────────────────────────────
# Solo necesario si el repo del frontend NO está como sibling de lulo-starter/.
# Usa ruta absoluta con forward slashes:
# FRONTEND_PATH=c:/Users/tu_usuario/proyectoWeb_Front/frontend_final
FRONTEND_PATH=
